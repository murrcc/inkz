<!-- ===== DESKTOP: file-tab vertical strip ===== -->
<nav class="scroll-indicator" role="navigation" aria-label="Page sections">
  <ol class="scroll-indicator-tabs">
    <li><a class="scroll-indicator-tab" data-section="hero"        href="#hero">01 / HERO</a></li>
    <li><a class="scroll-indicator-tab" data-section="wedge"       href="#wedge">02 / WEDGE</a></li>
    <li><a class="scroll-indicator-tab" data-section="methodology" href="#methodology">03 / METHODOLOGY</a></li>
    <li><a class="scroll-indicator-tab" data-section="whisper"     href="#whisper">04 / WHISPER</a></li>
    <li><a class="scroll-indicator-tab" data-section="about"       href="#about">05 / ABOUT</a></li>
    <li><a class="scroll-indicator-tab" data-section="contact"     href="#contact">06 / CONTACT</a></li>
    <li><a class="scroll-indicator-tab" data-section="footer"      href="#footer">07 / FOOTER</a></li>
  </ol>
</nav>

<!-- ===== MOBILE: thin scroll-progress bar at top ===== -->
<div class="scroll-progress-track" aria-hidden="true">
  <div class="scroll-progress-bar"></div>
</div>

<style>
  /* ===== DESKTOP STRIP ===== */

  .scroll-indicator {
    /* Hidden on mobile — revealed at >=1024px */
    display: none;
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100; /* above page content, below Whisper modal (z-index:1000) */
    padding-right: var(--space-6);
  }

  .scroll-indicator-tabs {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    align-items: flex-end;
  }

  .scroll-indicator-tab {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--type-100);
    font-weight: var(--weight-regular);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--graphite-soft);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-left: 1px solid var(--hairline);
    transition:
      color 0.15s var(--ease-out-quart),
      border-left-width 0.15s var(--ease-out-quart),
      border-left-color 0.15s var(--ease-out-quart),
      font-weight 0.15s var(--ease-out-quart);
    white-space: nowrap;
  }

  /* Hover: text becomes ink */
  .scroll-indicator-tab:hover,
  .scroll-indicator-tab:focus-visible {
    color: var(--ink);
    outline: none;
  }

  .scroll-indicator-tab:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  /* Active state — Option D: ink text + 2px ink border-left
     Choice rationale: forensic-red already appears in Hero (CASE FILE stamp) and
     Wedge ("leaks" underline). Applying it to a persistent fixed UI element would
     normalise the accent and drain its impact. Instead, option D uses ink weight —
     the border thickens from 1px hairline to 2px ink, and the text advances to full
     ink. This creates unambiguous visual priority using structural weight alone,
     keeping the forensic accent strictly rare. */
  .scroll-indicator-tab.is-active {
    color: var(--ink);
    font-weight: var(--weight-semibold);
    border-left: 2px solid var(--ink);
  }

  /* Reveal strip on desktop */
  @media (min-width: 1024px) {
    .scroll-indicator {
      display: block;
    }
  }

  /* ===== MOBILE PROGRESS BAR ===== */

  .scroll-progress-track {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    z-index: 100;
    /* On desktop the desktop strip handles navigation — hide the progress track */
    background: transparent;
  }

  .scroll-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--ink);
    transition: width 0.05s linear;
  }

  /* Hide mobile progress bar on desktop — the file-tab strip takes over */
  @media (min-width: 1024px) {
    .scroll-progress-track {
      display: none;
    }
  }
</style>

<script>
  (() => {
    const sections = ['hero', 'wedge', 'methodology', 'whisper', 'about', 'contact', 'footer'];
    const tabs = document.querySelectorAll('.scroll-indicator-tab');
    const progressBar = document.querySelector('.scroll-progress-bar');

    // ---- IntersectionObserver: active-tab highlighting ----
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && entry.intersectionRatio > 0.5) {
          const id = entry.target.id;
          tabs.forEach(t => t.classList.toggle('is-active', t.dataset.section === id));
        }
      });
    }, { threshold: [0.5] });

    sections.forEach(id => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });

    // ---- Scroll listener: mobile progress bar ----
    function updateProgress() {
      const scrollTop = window.scrollY;
      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
      if (progressBar) progressBar.style.width = `${progress}%`;
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  })();
</script>
