<section id="methodology" class="methodology">
  <hr class="hairline" />
  <div class="methodology-inner">

    <p class="mono file-marker">03 / METHODOLOGY</p>

    <h2 class="heading">The audit.</h2>

    <p class="framing">
      Every audit examines five categories where revenue typically leaks in mature small
      businesses. Each one is sized in dollars before any work is proposed.
    </p>

    <!-- ===== 5 LEAK CATEGORIES ===== -->
    <div class="categories">

      <div class="category" data-category="funnel">
        <div class="file-tab">
          <span class="tab-index mono">01</span>
          <span class="tab-name mono">Funnel</span>
        </div>
        <div class="file-body">
          <h3 class="category-name">Funnel leaks.</h3>
          <p class="category-desc">
            Show rates, no-shows, cancellations. The gap between someone enquiring and
            someone actually walking through the door. Measured as a conversion rate
            against your enquiry volume.
          </p>
        </div>
      </div>

      <div class="category" data-category="database">
        <div class="file-tab">
          <span class="tab-index mono">02</span>
          <span class="tab-name mono">Database</span>
        </div>
        <div class="file-body">
          <h3 class="category-name">Database leaks.</h3>
          <p class="category-desc">
            Missing contacts, dormant customers, CRM hygiene that quietly removes people
            from your reachable audience. We count the contacts you can actually message
            against the contacts who have ever transacted.
          </p>
        </div>
      </div>

      <div class="category" data-category="recurring">
        <div class="file-tab">
          <span class="tab-index mono">03</span>
          <span class="tab-name mono">Recurring Revenue</span>
        </div>
        <div class="file-body">
          <h3 class="category-name">Recurring revenue leaks.</h3>
          <p class="category-desc">
            Recall compliance, repurchase rates, customers who buy once and quietly leave.
            Measured against your category's expected repurchase interval.
          </p>
        </div>
      </div>

      <div class="category" data-category="pricing">
        <div class="file-tab">
          <span class="tab-index mono">04</span>
          <span class="tab-name mono">Pricing</span>
        </div>
        <div class="file-body">
          <h3 class="category-name">Pricing leaks.</h3>
          <p class="category-desc">
            Average ticket below the ceiling. Unsold premium tiers. Attach rates left on
            the table. The delta between what you charge and what a comparable business
            in your market charges.
          </p>
        </div>
      </div>

      <div class="category" data-category="acquisition">
        <div class="file-tab">
          <span class="tab-index mono">05</span>
          <span class="tab-name mono">Acquisition</span>
        </div>
        <div class="file-body">
          <h3 class="category-name">Acquisition leaks.</h3>
          <p class="category-desc">
            Untracked sources, blind paid-channel returns, marketing spend you cannot
            explain. Sized against what a same-category business spends to acquire a
            comparable customer.
          </p>
        </div>
      </div>

    </div><!-- /categories -->

    <!-- ===== ENGAGEMENT MODEL DIVIDER ===== -->
    <div class="model-divider">
      <hr class="hairline" />
      <p class="mono divider-label">// ENGAGEMENT MODEL</p>
    </div>

    <!-- ===== 4-PHASE ENGAGEMENT MODEL ===== -->
    <div class="phases">

      <div class="phase" data-phase="1">
        <div class="phase-number" aria-hidden="true">01</div>
        <div class="phase-content">
          <h3 class="phase-name">Walk-in or warm intro.</h3>
          <p class="phase-desc">
            Conversation is the qualifier. No cold outreach, no funnel. If you're here
            because someone handed you a card, that is already sufficient context for
            a first call.
          </p>
        </div>
      </div>

      <div class="phase-connector" aria-hidden="true"></div>

      <div class="phase" data-phase="2">
        <div class="phase-number" aria-hidden="true">02</div>
        <div class="phase-content">
          <h3 class="phase-name">Free diagnostic audit.</h3>
          <p class="phase-desc">
            Two to three weeks of focused analysis under NDA. Produces a proposal-grade
            written report. Each of the five categories above is sized in dollar terms.
            You keep the report regardless of what comes next.
          </p>
        </div>
      </div>

      <div class="phase-connector" aria-hidden="true"></div>

      <div class="phase" data-phase="3">
        <div class="phase-number" aria-hidden="true">03</div>
        <div class="phase-content">
          <h3 class="phase-name">Bespoke engagement proposal.</h3>
          <p class="phase-desc">
            Custom scope, custom price. Typical range: $50,000 to $150,000 depending on
            what the audit found and what fixing it requires. No packages, no tiers.
          </p>
        </div>
      </div>

      <div class="phase-connector" aria-hidden="true"></div>

      <div class="phase" data-phase="4">
        <div class="phase-number" aria-hidden="true">04</div>
        <div class="phase-content">
          <h3 class="phase-name">Execution.</h3>
          <p class="phase-desc">
            Three to six months. INKZ leads. Trusted contractors plug in per project.
            Reactivation campaigns launch in month one. Work is tracked against the
            dollar figures in the audit report.
          </p>
        </div>
      </div>

    </div><!-- /phases -->

  </div><!-- /methodology-inner -->
</section>

<style>
  .methodology {
    padding: var(--space-24) var(--space-8);
  }

  .methodology .hairline {
    margin-bottom: var(--space-24);
  }

  .methodology-inner {
    max-width: var(--max-body-width);
    margin: 0 auto;
  }

  /* ---- File marker ---- */
  .file-marker {
    color: var(--graphite-soft);
    margin-bottom: var(--space-8);
    max-width: none;
  }

  /* ---- Section heading ---- */
  .heading {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--type-600);
    letter-spacing: -0.02em;
    line-height: var(--leading-tight);
    color: var(--ink);
    margin-bottom: var(--space-6);
    max-width: none;
  }

  /* ---- Framing paragraph ---- */
  .framing {
    font-family: var(--font-body);
    font-size: var(--type-300);
    line-height: var(--leading-relaxed);
    color: var(--graphite);
    max-width: 56ch;
    margin-bottom: var(--space-16);
  }

  /* ===== LEAK CATEGORIES ===== */

  .categories {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: var(--space-16);
  }

  /* Each file */
  .category {
    border-top: 1px solid var(--hairline);
  }

  .category:last-child {
    border-bottom: 1px solid var(--hairline);
  }

  /* Index tab: sits above the file's top border, connected to it */
  .file-tab {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-3) 0 var(--space-2);
    border-bottom: 1px solid var(--hairline);
  }

  .tab-index {
    font-family: var(--font-mono);
    font-size: var(--type-100);
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    color: var(--graphite-soft);
  }

  .tab-name {
    font-family: var(--font-mono);
    font-size: var(--type-100);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    color: var(--graphite);
    text-transform: uppercase;
  }

  /* File body */
  .file-body {
    padding: var(--space-6) 0 var(--space-8);
  }

  .category-name {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: var(--type-500);
    letter-spacing: -0.02em;
    line-height: var(--leading-snug);
    color: var(--ink);
    margin-bottom: var(--space-3);
  }

  .category-desc {
    font-family: var(--font-body);
    font-size: var(--type-300);
    line-height: var(--leading-relaxed);
    color: var(--graphite);
    max-width: 58ch;
  }

  /* ===== ENGAGEMENT MODEL DIVIDER ===== */

  .model-divider {
    margin-bottom: var(--space-12);
  }

  .model-divider .hairline {
    margin-bottom: var(--space-4);
  }

  .divider-label {
    color: var(--graphite-soft);
    max-width: none;
  }

  /* ===== 4-PHASE MODEL ===== */

  .phases {
    display: flex;
    flex-direction: column;
  }

  .phase {
    display: grid;
    grid-template-columns: var(--space-16) 1fr;
    gap: 0 var(--space-6);
    align-items: start;
    padding: var(--space-6) 0;
  }

  /* Phase number: large display treatment */
  .phase-number {
    font-family: var(--font-mono);
    font-size: var(--type-700);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    color: var(--hairline);
    grid-column: 1;
    padding-top: 0.05em;
  }

  .phase-content {
    grid-column: 2;
  }

  .phase-name {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: var(--type-400);
    letter-spacing: -0.02em;
    line-height: var(--leading-snug);
    color: var(--ink);
    margin-bottom: var(--space-2);
  }

  .phase-desc {
    font-family: var(--font-body);
    font-size: var(--type-300);
    line-height: var(--leading-relaxed);
    color: var(--graphite);
    max-width: 52ch;
  }

  /* Hairline connector between phases */
  .phase-connector {
    grid-column: 1 / -1;
    height: 1px;
    background: var(--hairline);
    margin: 0;
  }

  /* ===== RESPONSIVE ===== */

  @media (max-width: 720px) {
    .methodology {
      padding: var(--space-16) var(--space-6);
    }

    .methodology .hairline {
      margin-bottom: var(--space-16);
    }

    .heading {
      font-size: var(--type-500);
    }

    .framing {
      margin-bottom: var(--space-12);
    }

    .categories {
      margin-bottom: var(--space-12);
    }

    .file-body {
      padding: var(--space-4) 0 var(--space-6);
    }

    .category-name {
      font-size: var(--type-400);
    }

    .phase {
      grid-template-columns: var(--space-12) 1fr;
      gap: 0 var(--space-4);
    }

    .phase-number {
      font-size: var(--type-600);
    }
  }

  @media (max-width: 480px) {
    .phase {
      grid-template-columns: 1fr;
      gap: var(--space-2) 0;
    }

    .phase-number {
      font-size: var(--type-500);
      color: var(--graphite-soft);
    }
  }
</style>
